{
  "kind": "collectionType",
  "collectionName": "perfils",
  "info": {
    "singularName": "perfil",
    "pluralName": "perfils",
    "displayName": "perfil"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "nomeCompleto": {
      "type": "string"
    },
    "telefone": {
      "type": "string"
    },
    "descricao": {
      "type": "blocks"
    },
    "foto": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images", "files", "videos", "audios"]
    },
    "tipoUsuario": {
      "type": "enumeration",
      "enum": ["cliente", "prestador"]
    },
    "solicitacoesComoCliente": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::solicitacao.solicitacao",
      "mappedBy": "cliente"
    },
    "servicos": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::servico.servico",
      "mappedBy": "prestador"
    },
    "solicitacoesComoPrestador": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::solicitacao.solicitacao",
      "mappedBy": "prestador"
    }
  }
}
