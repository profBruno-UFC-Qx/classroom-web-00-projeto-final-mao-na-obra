{
  "kind": "collectionType",
  "collectionName": "agendamentos",
  "info": {
    "singularName": "agendamento",
    "pluralName": "agendamentos",
    "displayName": "Agendamento"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "data": {
      "type": "date",
      "required": true
    },
    "horario": {
      "type": "string",
      "required": true
    },
    "observacoes": {
      "type": "blocks"
    },
    "situacao": {
      "type": "enumeration",
      "required": true,
      "default": "pendente",
      "enum": [
        "pendente",
        "aceito",
        "recusado",
        "concluido",
        "cancelado"
      ]
    },
    "valor_estimado": {
      "type": "decimal"
    },
    "cliente": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::cliente.cliente"
    },
    "trabalhador": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::trabalhador.trabalhador"
    }
  }
}
