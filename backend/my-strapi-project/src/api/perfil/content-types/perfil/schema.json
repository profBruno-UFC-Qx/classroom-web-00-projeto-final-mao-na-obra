{
  "kind": "collectionType",
  "collectionName": "perfils",
  "info": {
    "singularName": "perfil",
    "pluralName": "perfils",
    "displayName": "perfil"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "nomeCompleto": {
      "type": "string"
    },
    "telefone": {
      "type": "string"
    },
    "endereco": {
      "type": "string"
    },
    "descricao": {
      "type": "blocks"
    },
    "foto": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "tipoUsuario": {
      "type": "enumeration",
      "enum": [
        "cliente",
        "prestador"
      ]
    },
    "solicitacoesComoCliente": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::solicitacao.solicitacao",
      "mappedBy": "cliente"
    },
    "servicos": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::servico.servico",
      "mappedBy": "prestador"
    },
    "solicitacoesComoPrestador": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::solicitacao.solicitacao",
      "mappedBy": "prestador"
    },
    "users_permissions_user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user",
      "mappedBy": "perfil"
    }
  }
}
